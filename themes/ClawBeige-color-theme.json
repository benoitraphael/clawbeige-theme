  "tokenColors": [
    {
      "name": "Reset / Plain text",
      "scope": ["source", "text"],
      "settings": { "foreground": "#2C2420" }
    },
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#A89888", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other.using",
        "storage.type.class",
        "storage.type.function",
        "storage.modifier"
      ],
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": { "foreground": "#8A7868" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": { "foreground": "#7A5A20" }
    },
    {
      "name": "String escape sequences",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language.numeric"
      ],
      "settings": { "foreground": "#A04A20" }
    },
    {
      "name": "Constants & Booleans",
      "scope": [
        "constant.language",
        "constant.other"
      ],
      "settings": { "foreground": "#A04A20" }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#6A4A90" }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#2A5A8A" }
    },
    {
      "name": "Interfaces / Abstract types",
      "scope": "entity.name.type.interface",
      "settings": { "foreground": "#2A5A8A", "fontStyle": "italic" }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": { "foreground": "#2A5A8A", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#2C2420" }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameter variable"
      ],
      "settings": { "foreground": "#5A4A3A", "fontStyle": "italic" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#3A5A3A" }
    },
    {
      "name": "Imports / Module names",
      "scope": [
        "entity.name.module",
        "support.module"
      ],
      "settings": { "foreground": "#2A5A8A" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#8A4A20", "fontStyle": "italic" }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "HTML Attributes",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#3A5A3A" }
    },
    {
      "name": "HTML Attribute values",
      "scope": "string.quoted.double.html",
      "settings": { "foreground": "#7A5A20" }
    },
    {
      "name": "CSS Property",
      "scope": "support.type.property-name.css",
      "settings": { "foreground": "#3A5A3A" }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value",
        "meta.property-value"
      ],
      "settings": { "foreground": "#7A5A20" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.name.tag.css"
      ],
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "CSS Units / Numbers",
      "scope": "constant.numeric.css",
      "settings": { "foreground": "#A04A20" }
    },
    {
      "name": "Markdown Heading",
      "scope": "markup.heading",
      "settings": { "foreground": "#C15F3C", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#2C2420", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#2C2420", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Code",
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#7A5A20" }
    },
    {
      "name": "Markdown Link",
      "scope": "markup.underline.link",
      "settings": { "foreground": "#3A6898" }
    },
    {
      "name": "Markdown Quote",
      "scope": "markup.quote",
      "settings": { "foreground": "#A89888", "fontStyle": "italic" }
    },
    {
      "name": "Markdown List punctuation",
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "JSON Keys",
      "scope": "support.type.property-name.json",
      "settings": { "foreground": "#3A5A3A" }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation",
      "settings": { "foreground": "#8A7868" }
    },
    {
      "name": "Tag brackets",
      "scope": [
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "#A89888" }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": { "foreground": "#C13C3C", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": "invalid.deprecated",
      "settings": { "foreground": "#C08030", "fontStyle": "strikethrough" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable":             "#2C2420",
    "variable.readonly":    "#A04A20",
    "parameter":            { "foreground": "#5A4A3A", "fontStyle": "italic" },
    "function":             "#6A4A90",
    "method":               "#6A4A90",
    "class":                "#2A5A8A",
    "interface":            { "foreground": "#2A5A8A", "fontStyle": "italic" },
    "type":                 "#2A5A8A",
    "enum":                 "#2A5A8A",
    "enumMember":           "#A04A20",
    "namespace":            "#6A5848",
    "property":             "#3A5A3A",
    "keyword":              "#C15F3C",
    "modifier":             "#C15F3C",
    "comment":              { "foreground": "#A89888", "fontStyle": "italic" },
    "string":               "#7A5A20",
    "number":               "#A04A20",
    "regexp":               "#7A5A20",
    "operator":             "#8A7868",
    "decorator":            { "foreground": "#8A4A20", "fontStyle": "italic" },
    "typeParameter":        { "foreground": "#2A5A8A", "fontStyle": "italic" }
  }
}
