  "tokenColors": [
    {
      "name": "Reset / Plain text",
      "scope": ["source", "text"],
      "settings": { "foreground": "#e8e6e3" }
    },
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6a6158", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other.using",
        "storage.type.class",
        "storage.type.function",
        "storage.modifier"
      ],
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": { "foreground": "#9a9389" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": { "foreground": "#d4a96a" }
    },
    {
      "name": "String escape sequences",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#e8a87c" }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.language.numeric"
      ],
      "settings": { "foreground": "#e8a87c" }
    },
    {
      "name": "Constants & Booleans",
      "scope": [
        "constant.language",
        "constant.other"
      ],
      "settings": { "foreground": "#e8a87c" }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#d4b483" }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#c9a96e" }
    },
    {
      "name": "Interfaces / Abstract types",
      "scope": "entity.name.type.interface",
      "settings": { "foreground": "#c9a96e", "fontStyle": "italic" }
    },
    {
      "name": "Inherited class",
      "scope": "entity.other.inherited-class",
      "settings": { "foreground": "#c9a96e", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#e8e6e3" }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameter variable"
      ],
      "settings": { "foreground": "#b8a898", "fontStyle": "italic" }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#d4b483" }
    },
    {
      "name": "Imports / Module names",
      "scope": [
        "entity.name.module",
        "support.module"
      ],
      "settings": { "foreground": "#c9a96e" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#e8a87c", "fontStyle": "italic" }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "HTML Attributes",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#d4b483" }
    },
    {
      "name": "HTML Attribute values",
      "scope": "string.quoted.double.html",
      "settings": { "foreground": "#d4a96a" }
    },
    {
      "name": "CSS Property",
      "scope": "support.type.property-name.css",
      "settings": { "foreground": "#d4b483" }
    },
    {
      "name": "CSS Value",
      "scope": ["support.constant.property-value", "meta.property-value"],
      "settings": { "foreground": "#d4a96a" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.name.tag.css"
      ],
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "CSS Units / Numbers",
      "scope": "constant.numeric.css",
      "settings": { "foreground": "#e8a87c" }
    },
    {
      "name": "Markdown Heading",
      "scope": "markup.heading",
      "settings": { "foreground": "#C15F3C", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": "markup.bold",
      "settings": { "foreground": "#e8e6e3", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": "markup.italic",
      "settings": { "foreground": "#e8e6e3", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Code",
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#d4a96a" }
    },
    {
      "name": "Markdown Link",
      "scope": "markup.underline.link",
      "settings": { "foreground": "#7a9ec2" }
    },
    {
      "name": "Markdown Quote",
      "scope": "markup.quote",
      "settings": { "foreground": "#6a6158", "fontStyle": "italic" }
    },
    {
      "name": "Markdown List punctuation",
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": { "foreground": "#C15F3C" }
    },
    {
      "name": "JSON Keys",
      "scope": "support.type.property-name.json",
      "settings": { "foreground": "#d4b483" }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation",
      "settings": { "foreground": "#9a9389" }
    },
    {
      "name": "Tag brackets",
      "scope": [
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "#6a6158" }
    },
    {
      "name": "Invalid",
      "scope": "invalid",
      "settings": { "foreground": "#ff6b6b", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": "invalid.deprecated",
      "settings": { "foreground": "#e8a87c", "fontStyle": "strikethrough" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable":             "#e8e6e3",
    "variable.readonly":    "#e8a87c",
    "parameter":            { "foreground": "#b8a898", "fontStyle": "italic" },
    "function":             "#d4b483",
    "method":               "#d4b483",
    "class":                "#c9a96e",
    "interface":            { "foreground": "#c9a96e", "fontStyle": "italic" },
    "type":                 "#c9a96e",
    "enum":                 "#c9a96e",
    "enumMember":           "#e8a87c",
    "namespace":            "#9a9389",
    "property":             "#d4b483",
    "keyword":              "#C15F3C",
    "modifier":             "#C15F3C",
    "comment":              { "foreground": "#6a6158", "fontStyle": "italic" },
    "string":               "#d4a96a",
    "number":               "#e8a87c",
    "regexp":               "#d4a96a",
    "operator":             "#9a9389",
    "decorator":            { "foreground": "#e8a87c", "fontStyle": "italic" },
    "typeParameter":        { "foreground": "#c9a96e", "fontStyle": "italic" }
  }
}
