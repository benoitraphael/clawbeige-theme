{
  "name": "clawbeige-theme",
  "displayName": "ClawBeige",
  "description": "Warm beige theme inspired by Claude Desktop — soft beige tones, terracotta accents, light & dark variants. Tuned for prose writing: Inter for Markdown, JetBrains Mono for code (install via `brew install --cask font-inter font-jetbrains-mono`).",
  "keywords": [
    "claude",
    "anthropic",
    "beige",
    "warm",
    "dark",
    "light",
    "terracotta",
    "minimal"
  ],
  "version": "1.1.0",
  "publisher": "benoitraphael",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/benoitraphael/clawbeige-theme"
  },
  "icon": "icon.png",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/benoitraphael/clawbeige-theme/issues"
  },
  "homepage": "https://github.com/benoitraphael/clawbeige-theme#readme",
  "contributes": {
    "themes": [
      {
        "label": "ClawBeige",
        "uiTheme": "vs",
        "path": "./themes/ClawBeige-color-theme.json"
      },
      {
        "label": "ClawBeige Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/ClawBeige-Dark-color-theme.json"
      }
    ],
    "configurationDefaults": {
      "[ClawBeige]": {
        "editor.fontFamily": "'JetBrains Mono', 'SF Mono', Menlo, Consolas, 'DejaVu Sans Mono', monospace",
        "editor.fontSize": 13,
        "editor.lineHeight": 22,
        "editor.fontLigatures": true
      },
      "[markdown]": {
        "editor.fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
        "editor.fontSize": 13,
        "editor.lineHeight": 22,
        "editor.fontLigatures": false,
        "editor.wordWrap": "on"
      },
      "[plaintext]": {
        "editor.fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
        "editor.fontSize": 13,
        "editor.lineHeight": 22,
        "editor.wordWrap": "on"
      },
      "[mdx]": {
        "editor.fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
        "editor.fontSize": 13,
        "editor.lineHeight": 22,
        "editor.wordWrap": "on"
      }
    }
  }
}
